<Window x:Class="GHubXBOXProfileFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="G Hub XBOX Profile Fixer (Unofficial)"
        Width="1100" Height="760" MinWidth="960" MinHeight="650"
        WindowStartupLocation="CenterScreen" Background="{StaticResource CanvasBrush}"
        FontFamily="Segoe UI" UseLayoutRounding="True" SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="26,0">
                <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource PaleGreenBrush}" Margin="0,0,12,0">
                    <TextBlock Text="↗" Foreground="{StaticResource GreenBrush}" FontFamily="Segoe UI Semibold"
                               FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="G Hub XBOX Profile Fixer" FontFamily="Segoe UI Semibold" FontSize="18" VerticalAlignment="Center" />
                <Border Background="#F1F2F0" CornerRadius="5" Padding="9,4" Margin="12,0,0,0">
                    <TextBlock Text="Unofficial" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="16,38">
                    <Border x:Name="Step1Nav" CornerRadius="8" Padding="16,15" Margin="0,0,0,8" MouseLeftButtonUp="Step1Nav_Click">
                        <TextBlock x:Name="Step1NavText" Text="1     G Hub database" FontFamily="Segoe UI Semibold" FontSize="14" />
                    </Border>
                    <Border x:Name="Step2Nav" CornerRadius="8" Padding="16,15" Margin="0,0,0,8" MouseLeftButtonUp="Step2Nav_Click">
                        <TextBlock x:Name="Step2NavText" Text="2     XBOX games" FontFamily="Segoe UI Semibold" FontSize="14" />
                    </Border>
                    <Border x:Name="Step3Nav" CornerRadius="8" Padding="16,15" MouseLeftButtonUp="Step3Nav_Click">
                        <TextBlock x:Name="Step3NavText" Text="3     Create copy" FontFamily="Segoe UI Semibold" FontSize="14" />
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="44,30,44,28">
                <Grid x:Name="DatabasePage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="G Hub database" FontFamily="Segoe UI Semibold" FontSize="32" />
                        <TextBlock Text="Select the G Hub settings database you want to create a fixed copy from."
                                   Foreground="{StaticResource MutedBrush}" FontSize="15" Margin="0,5,0,0" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="LGHUB settings.db" FontFamily="Segoe UI Semibold" FontSize="16" />
                            <Grid Grid.Row="1" Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="DatabasePathBox" Height="40" FontSize="14" VerticalContentAlignment="Center"
                                         Padding="11,0" BorderBrush="#C8CBC8" BorderThickness="1" />
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" Click="BrowseDatabase_Click" />
                            </Grid>
                            <TextBlock x:Name="DatabaseStatusText" Grid.Row="2" Text="Select your settings.db"
                                       Foreground="{StaticResource MutedBrush}" Margin="0,10,0,0" FontSize="13" />
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="2" Text="◇  Your original database will only be read. The app always creates a separate copy."
                               Foreground="{StaticResource MutedBrush}" FontSize="13" Margin="4,18,0,0" />
                    <Button Grid.Row="4" Content="Continue" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right"
                            Width="150" Click="DatabaseContinue_Click" />
                </Grid>

                <Grid x:Name="GamesPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,18">
                        <TextBlock Text="XBOX games" FontFamily="Segoe UI Semibold" FontSize="32" />
                        <TextBlock Text="Select the games you want to add to G Hub." Foreground="{StaticResource MutedBrush}" FontSize="15" Margin="0,5,0,0" />
                    </StackPanel>

                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="18,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="settings.db" FontFamily="Segoe UI Semibold" FontSize="15" />
                                <TextBlock x:Name="DatabasePathSummary" Foreground="{StaticResource MutedBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="✓  Ready" Foreground="{StaticResource GreenBrush}" VerticalAlignment="Center" Margin="16,0" />
                            <Button Grid.Column="2" Content="Change" Style="{StaticResource SecondaryButton}" Click="ChangeDatabase_Click" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,14,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="↻  Scan again" Style="{StaticResource SecondaryButton}" Click="ScanAgain_Click" />
                        <Button Grid.Column="1" Content="Add folder" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="AddFolder_Click" />
                        <Button Grid.Column="2" Content="Add executable" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="AddExecutable_Click" />
                        <TextBlock x:Name="ScanSummaryText" Grid.Column="3" Text="Not scanned yet" Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>

                    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="GamesItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,13">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="46" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="150" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding Selected}" IsEnabled="{Binding CanSelect}" VerticalAlignment="Center"
                                                          Click="GameCheckBox_Click" />
                                                <Border Grid.Column="1" Width="38" Height="38" CornerRadius="7" Background="#F1F2F0" VerticalAlignment="Center">
                                                    <Image Source="{Binding Icon}" Width="34" Height="34" Stretch="Uniform" />
                                                </Border>
                                                <StackPanel Grid.Column="2" Margin="12,0,18,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontFamily="Segoe UI Semibold" FontSize="15" />
                                                    <TextBlock Text="{Binding ExecutablePath}" Foreground="{StaticResource MutedBrush}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{Binding Status}" Foreground="{Binding StatusBrush}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="13" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="4" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectedCountText" Text="0 games selected" FontFamily="Segoe UI Semibold" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="◇  Your original database will not be changed." Foreground="{StaticResource MutedBrush}"
                                   VerticalAlignment="Center" Margin="26,0,0,0" />
                        <Button Grid.Column="2" Content="Continue" Style="{StaticResource PrimaryButton}" Width="150" Click="GamesContinue_Click" />
                    </Grid>
                </Grid>

                <Grid x:Name="CreatePage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,0,24">
                        <TextBlock Text="Create fixed copy" FontFamily="Segoe UI Semibold" FontSize="32" />
                        <TextBlock Text="Review the selection, then create a new G Hub database." Foreground="{StaticResource MutedBrush}" FontSize="15" Margin="0,5,0,0" />
                    </StackPanel>
                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="22">
                        <StackPanel>
                            <TextBlock x:Name="CreateCountText" FontFamily="Segoe UI Semibold" FontSize="18" />
                            <TextBlock x:Name="CreateNamesText" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <TextBlock x:Name="CreateSourceText" Foreground="{StaticResource MutedBrush}" Margin="0,16,0,0" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <TextBlock Grid.Row="2" Text="✓  The source database remains untouched. The new copy must pass all validation checks."
                               Foreground="{StaticResource GreenBrush}" Margin="4,18,0,0" />
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Back" Style="{StaticResource SecondaryButton}" Width="100" Margin="0,0,10,0" Click="BackToGames_Click" />
                        <Button Content="Create fixed database" Style="{StaticResource PrimaryButton}" Width="210" Click="CreateDatabase_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
